{
  "files": [
    {
      "path": "examples/sample.json",
      "targetPath": "examples/sample.output.json",
      "rules": [
        {
          "sourcePath": "$.person.name",
          "targetPath": "$.metadata.displayName"
        },
        {
          "sourcePath": "$.person.favoriteShow",
          "targetPath": "$.metadata.favoriteShowDe",
          "replaceFromMap": "commentTranslations"
        },
        {
          "sourcePath": "$.items[0].id",
          "targetPath": "$.summary.primaryItemId"
        }
      ]
    }
  ]
}
